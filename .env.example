PORT=3000

# Optional — when set, verification codes are emailed via SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Alias also accepted: SMTP_PASSWORD
MAIL_FROM=

# Without SMTP, codes are logged to data/dev-verification-codes.log
# and shown on the workshop page for local testing.

# Mailchimp — homepage lead magnet (free PDF)
# API key looks like: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us21
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
# Optional if not using the suffix from the API key:
MAILCHIMP_SERVER_PREFIX=
# subscribed (default) or pending (double opt-in)
MAILCHIMP_STATUS=subscribed

# Signs download tokens (defaults to Mailchimp key or a local fallback)
DOWNLOAD_SECRET=
